#!/usr/bin/env bash
# Usage: ./script/test/python <major-version> <image-ref>
set -euo pipefail

version="${1:?usage: $0 <major-version> <image-ref>}"
image="${2:?usage: $0 <major-version> <image-ref>}"
dir="$(cd "$(dirname "$0")" && pwd)"

exec container-structure-test test \
  --image "$image" \
  --config "$dir/common.yaml" \
  --config "$dir/python-$version.yaml"
